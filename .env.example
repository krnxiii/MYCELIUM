# Mycelium — environment config
# Copy to .env and fill in your values: cp .env.example .env

# ── Embeddings (required for quickstart) ─────────────────────────
MYCELIUM_SEMANTIC__PROVIDER=api
MYCELIUM_SEMANTIC__API_KEY=your_deepinfra_api_key
MYCELIUM_SEMANTIC__API_BASE_URL=https://api.deepinfra.com/v1/openai

# ── Neo4j ────────────────────────────────────────────────────────
MYCELIUM_NEO4J__URI=bolt://localhost:7687
MYCELIUM_NEO4J__USER=neo4j
MYCELIUM_NEO4J__PASSWORD=password

# ── LLM (extraction via Claude Code CLI — uses your CC subscription) ─
# MYCELIUM_LLM__MODEL=sonnet          # sonnet | haiku | opus
#
# Advanced (VPS/headless without CC CLI — direct API via httpx):
# MYCELIUM_LLM__PROVIDER=api
# MYCELIUM_LLM__API_BASE=https://api.anthropic.com/v1
# MYCELIUM_LLM__MODEL=anthropic/claude-sonnet-4-20250514
# MYCELIUM_LLM__API_KEY=sk-ant-...

# ── MCP Server ─────────────────────────────────────────────────
# MYCELIUM_MCP__TRANSPORT=stdio        # stdio | streamable-http
# MYCELIUM_MCP__HOST=0.0.0.0
# MYCELIUM_MCP__PORT=9631
MYCELIUM_MCP__AUTH_TOKEN=              # Bearer token for HTTP auth (empty = no auth)

# ── Telegram Bot ─────────────────────────────────────────────────
MYCELIUM_TELEGRAM__BOT_TOKEN=
MYCELIUM_TELEGRAM__OWNER_CHAT_ID=0
# MYCELIUM_TELEGRAM__MCP_URL=http://localhost:9631/mcp
# MYCELIUM_TELEGRAM__MCP_AUTH_TOKEN=   # fallback: uses MYCELIUM_MCP__AUTH_TOKEN

# ── VPS (set by install-vps.sh) ────────────────────────────────
# TAILSCALE_AUTHKEY=tskey-auth-...     # Tailscale auth key for mesh VPN

# ── Owner (optional, set during install or auto-learned) ──────
MYCELIUM_OWNER__NAME=

# ── Render (Sigma.js graph viewer, optional) ─────────────────
MYCELIUM_RENDER__ENABLED=false
# MYCELIUM_RENDER__PORT=9633

# ── Obsidian (visualization layer) ────────────────────────────
MYCELIUM_OBSIDIAN__ENABLED=true
MYCELIUM_OBSIDIAN__PROJECT_NEURONS=false   # project neurons as .md in vault/neurons/

# ── Interaction (question verbosity) ──────────────────────────
# MYCELIUM_INTERACTION__LEVEL=balanced   # silent | minimal | balanced | curious

# ── Logging ──────────────────────────────────────────────────────
# MYCELIUM_LOG__LEVEL=DEBUG
